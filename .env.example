# Copy to `.env` and fill in. `.env` is gitignored.
# Forge works fully offline with no keys set (deterministic echo provider).

# --- Provider API keys (optional) ------------------------------------------
# Provider auto-selection picks the default provider for routing:
#   - ANTHROPIC_API_KEY set                 -> Anthropic (Claude) is the default.
#   - OPENAI_API_KEY set, ANTHROPIC unset   -> OpenAI (GPT) is the default.
#   - no cloud key, Ollama reachable        -> Ollama (local models) is the default.
#   - multiple set                          -> Anthropic > OpenAI > Ollama; others usable.
#   - none of the above                     -> Echo offline provider (no key, no network).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Ollama (local LLM, optional) ------------------------------------------
# Ollama needs no API key and is built in (uses httpx, no extra package). Run
# `ollama serve` and pull a model (e.g. `ollama pull llama3.1:8b`). Forge auto-detects
# a local server; set this only to point at a custom or remote Ollama.
# Default: http://localhost:11434
OLLAMA_BASE_URL=

# --- Amazon Bedrock (optional) ---------------------------------------------
# Run models inside your own AWS account via the [bedrock] extra (boto3). Uses the
# standard AWS credential chain (env vars, ~/.aws/credentials, IAM role, SSO);
# Forge auto-detects Bedrock when AWS credentials are resolvable.
AWS_REGION=
# Named profile from ~/.aws/credentials (optional).
AWS_PROFILE=
# Overrides the region for Bedrock only (falls back to AWS_REGION, then us-east-1).
BEDROCK_REGION=

# --- Memory (RAG retrieval, optional) --------------------------------------
# Retrieval-memory backend (used by forge.memory.build_memory):
#   - inmemory (default) -> zero-dependency, in-process, not persisted.
#   - sqlite             -> durable across restarts; needs the [sqlite] extra
#                           (pip install "agentforge-oss[sqlite]").
FORGE_MEMORY_BACKEND=inmemory
# Database file path used when FORGE_MEMORY_BACKEND=sqlite.
FORGE_MEMORY_PATH=forge_memory.db

# --- Routing ---------------------------------------------------------------
# balanced | cost_optimized | quality_first | fixed
FORGE_ROUTING_STRATEGY=balanced
# Used by the 'fixed' strategy and as a fallback default.
FORGE_DEFAULT_MODEL=claude-opus-4-8

# --- Budgets ---------------------------------------------------------------
# Hard cap on spend per run (USD). Leave blank for no cap.
FORGE_MAX_USD_PER_RUN=

# --- Observability ---------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
FORGE_LOG_LEVEL=INFO
# true to emit JSON logs for aggregation/SIEM.
FORGE_JSON_LOGS=false
# OpenTelemetry export (needs the [otel] extra). Each run becomes a tree of spans
# plus metrics. Leave the endpoint blank to print to the console (zero infra).
FORGE_OTEL_ENABLED=false
FORGE_OTEL_ENDPOINT=
FORGE_OTEL_SERVICE_NAME=forge

# --- Compliance ------------------------------------------------------------
FORGE_AUDIT_ENABLED=true
FORGE_AUDIT_PATH=audit/forge-audit.jsonl
FORGE_REDACT_PII=true
